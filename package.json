{
  "name": "ai-on-call",
  "version": "1.0.0",
  "description": "Control AI coding assistants (Claude, OpenCode, Qwen) from Telegram",
  "main": "dist/index.js",
  "bin": {
    "ai-on-call": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup-config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "scripts/",
    "config.example.toml",
    "README.md",
    "README.zh-TW.md",
    "README.zh-CN.md",
    "locales/"
  ],
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "ai",
    "code-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "telegraf": "^4.16.3",
    "toml": "^3.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
